# .env.example — local development configuration template.
#
# Copy this file to `.env` for local dev. `.env` is in .gitignore — DO NOT
# commit a real `.env`. Production secrets are injected via the deployment
# environment (Docker Compose env_file, Kubernetes secrets, etc.), never
# checked into the repo.
#
# If you accidentally commit a `.env`, treat the value of every secret here
# as compromised: rotate JWT_SECRET, rotate DB password, restart processes.

# --- FOCAS / FANUC SDK -------------------------------------------------------

# Directory containing Fwlib64.dll, fwlibe64.dll, fwlib30i64.dll. Loaded by
# shared/focas/client.py on startup. Windows-only path; on Linux/macOS the
# client falls back to the mock harness (FOCAS_MODE=mock).
FOCAS_DLL_DIR=C:\Fanuc\FwLib64-runtime

# `real` for actual FOCAS calls (requires DLLs above), `mock` for the labeled
# mock harness in shared/focas/mock.py. Default in client.py is `real`; mock
# requires explicit opt-in to prevent accidental dev-mode in production.
FOCAS_MODE=real

# --- Database ----------------------------------------------------------------

# PostgreSQL DSN. Schemas in use: tooling, shared. Tracker schema is read-only
# from this app's perspective and not migrated by tooling Alembic — see
# migrations/env.py R1 guard.
#
# Local dev: start the Docker Postgres with
#   docker compose -f docker-compose.dev.yml up -d
# then use the URL below (port 5433, dev-only password).
# Production: a separate URL with the tooling_app role and a rotated
# password — see docs/runbooks/phase-2-db-setup.md (Phase 2).
DATABASE_URL=postgresql://pottracker_dev:dev_only_not_for_prod@localhost:5433/pottracker

# --- Auth --------------------------------------------------------------------

# Symmetric secret for JWT signing. MUST be replaced before any non-local use.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=change-me

# Token lifetimes (seconds). Operator session is short-lived; refresh longer.
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=86400

# --- Logging -----------------------------------------------------------------

# DEBUG | INFO | WARNING | ERROR. Production: INFO. Local FOCAS bring-up: DEBUG.
LOG_LEVEL=INFO
